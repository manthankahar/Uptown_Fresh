<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard - UptownFresh</title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include("partials/navbar") %>

<h1 class="page-title">
Admin Dashboard
</h1>

<div class="admin-cards">

<div class="admin-card">

<h2>📦 Products</h2>

<h1 id="totalProducts">0</h1>

</div>

<div class="admin-card">

<h2>👤 Users</h2>

<h1 id="totalUsers">0</h1>

</div>

<div class="admin-card">

<h2>🛒 Orders</h2>

<h1 id="totalOrders">0</h1>

</div>

<div class="admin-card">

<h2>💰 Revenue</h2>

<h1 id="totalRevenue">₹0</h1>

</div>

</div>

<p style="text-align:center;margin-bottom:30px;">
Manage Products & Store Operations
</p>

<div class="admin-cards">

<div class="admin-card">
<h2>Add Product</h2>
<p>Add new fruits and vegetables</p>

<a href="/addProduct" class="btn">
Add Product
</a>
</div>

<div class="admin-card">
<h2>Manage Products</h2>
<p>Delete or update products</p>

<a href="/products" class="btn">
Manage
</a>
</div>

<div class="admin-card">
<h2>Total Store</h2>
<p>View all available products</p>

<a href="/products" class="btn">
View Products
</a>
</div>

</div>

</div>

<%- include("partials/footer") %>

<script src="admin.js"></script>
<script src="dashboard.js"></script>

</body>
</html>
