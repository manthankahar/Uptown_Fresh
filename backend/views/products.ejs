<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Products - UptownFresh</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include("partials/navbar") %>

<h1 class="page-title">
Our Fresh Products
</h1>

<!-- Search Box -->

<div
style="
max-width:1200px;
margin:20px auto;
padding:0 20px;
"
>

<input
type="text"
id="searchInput"
placeholder="🔍 Search Products..."
style="
width:100%;
padding:15px;
border-radius:10px;
border:1px solid #ccc;
font-size:16px;
outline:none;
"
>

</div>

<!-- Category Filter -->

<div
style="
max-width:1200px;
margin:15px auto;
padding:0 20px;
"
>

<select
id="categoryFilter"
style="
width:100%;
padding:15px;
border-radius:10px;
border:1px solid #ccc;
font-size:16px;
"
>

<option value="all">
All Categories
</option>

<option value="General">
General
</option>

<option value="Fruits">
Fruits
</option>

<option value="Vegetables">
Vegetables
</option>

<option value="Dairy">
Dairy
</option>

<option value="Juice">
Juice
</option>

</select>

</div>

<!-- Products -->

<div
id="products-container"
class="products-container"
>

Loading Products...

</div>

<%- include("partials/footer") %>

<script src="/js/toast.js"></script>
<script src="/js/products.js"></script>

</body>

</html>