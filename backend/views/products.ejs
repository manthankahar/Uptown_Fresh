<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Products - UptownFresh</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include("partials/navbar") %>

<h1 class="page-title">
Our Fresh Products
</h1>

<!-- Filters -->

<div
style="
max-width:1200px;
margin:20px auto;
padding:0 20px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:15px;
"
>

<!-- Search -->

<input
type="text"
id="searchInput"
placeholder="🔍 Search Products..."
style="
padding:15px;
border-radius:10px;
border:1px solid #ccc;
font-size:16px;
outline:none;
"
>

<!-- Category -->

<select
id="categoryFilter"
style="
padding:15px;
border-radius:10px;
border:1px solid #ccc;
font-size:16px;
"
>

<option value="All">All Categories</option>
<option value="General">General</option>
<option value="Fruits">Fruits</option>
<option value="Vegetables">Vegetables</option>
<option value="Dairy">Dairy</option>
<option value="Juice">Juice</option>

</select>

<!-- Price -->

<select
id="priceFilter"
style="
padding:15px;
border-radius:10px;
border:1px solid #ccc;
font-size:16px;
"
>

<option value="">
All Prices
</option>

<option value="0-100">
₹0 - ₹100
</option>

<option value="100-300">
₹100 - ₹300
</option>

<option value="300-100000">
₹300+
</option>

</select>

<!-- Sort -->

<select
id="sortFilter"
style="
padding:15px;
border-radius:10px;
border:1px solid #ccc;
font-size:16px;
"
>

<option value="">
Latest
</option>

<option value="priceLow">
Price Low → High
</option>

<option value="priceHigh">
Price High → Low
</option>

<option value="name">
Name A → Z
</option>

</select>

</div>

<!-- Products -->

<div
id="products-container"
class="products-container"
>

Loading Products...

</div>

<!-- ===============================
Product Details Modal
=============================== -->

<div id="productModal" class="product-modal">

    <div class="product-modal-content">

        <span
            class="close-modal"
            onclick="closeProductModal()">
            &times;
        </span>

        <div class="product-modal-grid">

            <!-- Left -->

            <div class="product-left">

                <img
                    id="modalImage"
                    src=""
                    alt=""
                    class="modal-product-image">

            </div>

            <!-- Right -->

            <div class="product-right">

                <h1 id="modalName"></h1>

                <div
                    id="modalRating"
                    class="modal-rating">
                </div>

                <h2 id="modalPrice"></h2>

                <p id="modalCategory"></p>

                <p id="modalStock"></p>

                <p id="modalDescription"></p>
                

                <div class="quantity-box">

                    <hr style="margin:20px 0;">

                    <button
                        onclick="decreaseQty()">
                        -
                    </button>

                    <span id="modalQty">
                        1
                    </span>

                    <button
                        onclick="increaseQty()">
                        +
                    </button>

                </div>

                <div class="modal-buttons">

<button
class="btn"
onclick="addToCart(selectedProduct)">
🛒 Add To Cart
</button>

                    <!-- <button
                        class="btn"
                        style="background:#e74c3c"
                        id="wishlistBtn">
                        ❤️ Wishlist
                    </button> -->

                    <button
class="btn"
style="background:#e74c3c"
onclick="addToWishlist()">
❤️ Wishlist
</button>

                </div>

            </div>

        </div>

        <hr style="margin:35px 0;">

        <h2>
            ⭐ Customer Reviews
        </h2>

        <div id="reviewsContainer">

            No Reviews Yet

        </div>

        <hr style="margin:35px 0;">

        <h2>
            Write Review
        </h2>

        <div class="review-form">

            <select id="reviewRating">

                <option value="5">
                    ⭐⭐⭐⭐⭐
                </option>

                <option value="4">
                    ⭐⭐⭐⭐
                </option>

                <option value="3">
                    ⭐⭐⭐
                </option>

                <option value="2">
                    ⭐⭐
                </option>

                <option value="1">
                    ⭐
                </option>

            </select>

            <textarea
                id="reviewComment"
                placeholder="Write Your Review...">
            </textarea>

            <button
                class="btn"
                id="submitReviewBtn">

                Submit Review

            </button>

        </div>

    </div>

</div>

<!-- Stock Modal -->

<div id="stockModal" class="stock-modal">

<div class="stock-box">

<h2>
Update Stock
</h2>

<input
type="number"
id="stockValue"
min="0"
>

<div class="stock-buttons">

<button onclick="updateStock()">
Save
</button>

<button onclick="closeStockModal()">
Cancel
</button>

</div>

</div>

</div>

<%- include("partials/footer") %>

<script src="/toast.js"></script>
<script src="/products.js"></script>

</body>

</html>