<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Shopping Cart</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include("partials/navbar") %>

<div class="cart-container">

<h1 class="page-title">
🛒 My Shopping Cart
</h1>

<div id="cartItems"></div>

<hr style="margin:20px 0;">

<h2 id="subTotal"></h2>

<h2 id="delivery"></h2>

<h2 id="grandTotal"></h2>

<a href="/checkout" class="btn">
Proceed To Checkout
</a>

</div>

<%- include("partials/footer") %>

<script>

let cart =
JSON.parse(
localStorage.getItem("cart")
) || [];

function loadCart(){

const cartItems =
document.getElementById("cartItems");

if(cart.length===0){

cartItems.innerHTML=`

<div
style="
text-align:center;
padding:50px;
"
>

<h2>
🛒 Your Cart is Empty
</h2>

<p>
Add some fresh products.
</p>

<a
href="/products"
class="btn"
>

Continue Shopping

</a>

</div>

`;

document.getElementById(
"subTotal"
).innerText="";

document.getElementById(
"delivery"
).innerText="";

document.getElementById(
"grandTotal"
).innerText="";

return;

}

let html="";

let total=0;

cart.forEach((item,index)=>{

total += Number(item.price);

html += `

<div
class="cart-item"
>

<div
style="
display:flex;
align-items:center;
gap:15px;
"
>

<img
src="${item.image}"
style="
width:90px;
height:90px;
border-radius:10px;
object-fit:cover;
"
>

<div>

<h3>${item.name}</h3>

<p>${item.description}</p>

<p
style="
color:#27ae60;
font-weight:bold;
"
>

₹${item.price}

</p>

</div>

</div>

<button

onclick="removeItem(${index})"

style="
background:red;
color:white;
padding:10px 18px;
border:none;
border-radius:6px;
cursor:pointer;
"

>

🗑 Remove

</button>

</div>

`;

});

cartItems.innerHTML=html;

const delivery = 50;

document.getElementById(
"subTotal"
).innerText =
"Subtotal : ₹"+total;

document.getElementById(
"delivery"
).innerText =
"Delivery : ₹"+delivery;

document.getElementById(
"grandTotal"
).innerText =
"Grand Total : ₹"+(total+delivery);

}

function removeItem(index){

cart.splice(index,1);

localStorage.setItem(
"cart",
JSON.stringify(cart)
);

loadCart();

}

loadCart();

</script>

</body>

</html>