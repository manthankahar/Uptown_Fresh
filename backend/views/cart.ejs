async function loadCart(){

const token =
localStorage.getItem("token");

if(!token){

alert("Please Login First");

window.location.href="/login";

return;

}

const response =
await fetch(
"http://localhost:5000/api/cart",
{

headers:{
Authorization:`Bearer ${token}`
}

}

);

const cart =
await response.json();

const cartItems =
document.getElementById("cartItems");

if(
!cart.products ||
cart.products.length===0
){

cartItems.innerHTML=`

<div style="text-align:center;padding:50px;">

<h2>🛒 Your Cart is Empty</h2>

<p>Add Some Products</p>

<a href="/products" class="btn">

Continue Shopping

</a>

</div>

`;

document.getElementById("subTotal").innerText="";
document.getElementById("delivery").innerText="";
document.getElementById("grandTotal").innerText="";

return;

}

let html="";

let total=0;

cart.products.forEach(item=>{

const product =
item.productId;

const quantity =
item.quantity;

const price =
product.price * quantity;

total += price;

html += `

<div class="cart-item">

<div
style="
display:flex;
align-items:center;
gap:15px;
">

<img
src="${product.image}"
style="
width:90px;
height:90px;
border-radius:10px;
object-fit:cover;
">

<div>

<h3>${product.name}</h3>

<p>${product.description}</p>

<div
style="
display:flex;
align-items:center;
gap:10px;
margin:10px 0;
"
>

<button
onclick="decreaseQuantity('${product._id}')"
style="
width:35px;
height:35px;
border:none;
background:#e74c3c;
color:white;
border-radius:6px;
cursor:pointer;
font-size:18px;
"
>

-

</button>

<b>${quantity}</b>

<button
onclick="increaseQuantity('${product._id}')"
style="
width:35px;
height:35px;
border:none;
background:#27ae60;
color:white;
border-radius:6px;
cursor:pointer;
font-size:18px;
"
>

+

</button>

</div>

<p style="color:#27ae60;">

₹${price}

</p>

</div>

</div>

<button

onclick="removeItem('${product._id}')"

style="
background:red;
color:white;
padding:10px 18px;
border:none;
border-radius:6px;
cursor:pointer;
"

>

🗑 Remove

</button>

</div>

`;

});

cartItems.innerHTML=html;

const delivery =
total>0 ? 50 : 0;

document.getElementById("subTotal").innerText=
"Subtotal : ₹"+total;

document.getElementById("delivery").innerText=
"Delivery : ₹"+delivery;

document.getElementById("grandTotal").innerText=
"Grand Total : ₹"+(total+delivery);

}

async function removeItem(id){

const token =
localStorage.getItem("token");

const response =
await fetch(

`http://localhost:5000/api/cart/${id}`,

{

method:"DELETE",

headers:{

Authorization:`Bearer ${token}`

}

}

);

const data =
await response.json();

showToast(data.message,"success");

loadCart();

}

loadCart();

